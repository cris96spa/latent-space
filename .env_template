# Optional overrides for latent_space.core.settings.AppSettings.
# Environment variables are prefixed LATENT_SPACE_ and override configs/app.yaml.
# The app serves out of the box with no .env; these are only for non-default setups.

# CORS origins allowed to reach the API cross-origin (JSON array). Empty in the
# single-origin production deploy, where the edge proxies /api to the backend.
# LATENT_SPACE_ALLOWED_ORIGINS='["http://localhost:5173"]'

# Root directory holding authored site content (projects, chat).
# LATENT_SPACE_CONTENT_ROOT=content
