{
  "services": {
    "frontend": {
      "root": "frontend/",
      "framework": "vite",
      "rewrites": [{ "source": "/(.*)", "destination": "/index.html" }]
    },
    "backend": {
      "root": ".",
      "framework": "fastapi",
      "entrypoint": "asgi:app",
      "functions": {
        "asgi.py": {
          "excludeFiles": "{frontend/**,tests/**,docs/**,site/**,.venv/**,**/__pycache__/**}"
        }
      }
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": { "service": "backend" } },
    { "source": "/(.*)", "destination": { "service": "frontend" } }
  ]
}
